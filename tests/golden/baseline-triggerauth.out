---
# Source: common-smoke/templates/all.yaml
apiVersion: keda.sh/v1alpha1
kind: ClusterTriggerAuthentication
metadata:
  name: cluster-iam
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: ta-app
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
spec:
  podIdentity: 
    provider: aws-eks
---
# Source: common-smoke/templates/all.yaml
apiVersion: keda.sh/v1alpha1
kind: TriggerAuthentication
metadata:
  name: redis-auth
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: ta-app
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
spec:
  secretTargetRef: 
    - key: password
      name: redis-credentials
      parameter: password
