---
# Source: common-smoke/templates/all.yaml
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: keda-app
    app.kubernetes.io/component: web
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  maxUnavailable: 25%
  selector:
    matchLabels:
      app.kubernetes.io/name: keda-app
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ServiceAccount
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: keda-app
    app.kubernetes.io/component: web
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: keda-app
    app.kubernetes.io/component: web
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
data:
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Service
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: keda-app
    app.kubernetes.io/component: web
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8080
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: keda-app
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: keda-app
    app.kubernetes.io/component: web
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  minReadySeconds: 10
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 25%
      maxSurge: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: keda-app
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        helm.sh/chart: common-smoke-0.1.0
        app.kubernetes.io/name: keda-app
        app.kubernetes.io/component: web
        helm.sh/environment: dev
        app.kubernetes.io/instance: smoke
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/version: "7.8.9"
    spec:
      containers:
        - name: web
          image: ghcr.io/example/web:1.0.0
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: http
            containerPort: 8080
            protocol: TCP
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
              - ALL
      terminationGracePeriodSeconds: 30
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: keda.sh/v1alpha1
kind: ScaledObject
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: keda-app
    app.kubernetes.io/component: web
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  scaleTargetRef:
    name: web
    kind: Deployment
  pollingInterval: 30
  cooldownPeriod: 180
  minReplicaCount: 0
  maxReplicaCount: 0
  idleReplicaCount: 0
  advanced:
    restoreToOriginalReplicaCount: false
  fallback:
    failureThreshold: 3
    replicas: 1
  triggers:
    - type: cron
      metadata:
        timezone: "UTC"
        start: "0 8 * * *"
        end: "0 20 * * *"
        desiredReplicas: "3"
