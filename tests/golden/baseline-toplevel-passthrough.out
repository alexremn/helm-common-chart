---
# Source: common-smoke/templates/all.yaml
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-dns
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: toplevel-passthrough
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec: 
  egress:
  - ports:
    - port: 53
      protocol: UDP
    to: []
  podSelector: {}
  policyTypes:
  - Egress
---
# Source: common-smoke/templates/all.yaml
apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: shared-alerts
  labels:
    
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: toplevel-passthrough
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  groups: 
    - name: shared
      rules:
      - alert: SharedDown
        expr: up == 0
        for: 5m
