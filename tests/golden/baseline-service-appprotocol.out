metadata:
  name: web
  labels:
    app.kubernetes.io/name: svc-ap-app
    app.kubernetes.io/component: web
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
spec:
  maxUnavailable: 25%
  selector:
    matchLabels:
      app.kubernetes.io/name: svc-ap-app
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
