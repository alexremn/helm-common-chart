---
# Source: common-smoke/templates/all.yaml
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: app-secrets
  labels: 
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: extsecret-namespaced-app
    app.kubernetes.io/component: web
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
  annotations: 
    force-sync: "<NOW>"
spec:
  refreshInterval: "10000h"
  secretStoreRef:
    name: my-namespaced-store
    kind: SecretStore
  target:
    name: app-secrets
    creationPolicy: Owner
  data:
      - secretKey: DB_PASSWORD
        remoteRef:
          key: /apps/internal/api
          property: DB_PASSWORD
      - secretKey: API_KEY
        remoteRef:
          key: /apps/internal/api
          property: API_KEY
