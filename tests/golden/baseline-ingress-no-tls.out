data:
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Service
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: ingress-no-tls
    app.kubernetes.io/component: web
    helm.sh/environment: staging
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8080
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: ingress-no-tls
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: ingress-no-tls
    app.kubernetes.io/component: web
    helm.sh/environment: staging
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
spec:
  replicas: 1
  minReadySeconds: 10
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 25%
      maxSurge: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: ingress-no-tls
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        helm.sh/chart: common-smoke-0.1.0
        app.kubernetes.io/name: ingress-no-tls
        app.kubernetes.io/component: web
        helm.sh/environment: staging
        app.kubernetes.io/instance: smoke
        app.kubernetes.io/managed-by: Helm
    spec:
      containers:
        - name: web
          image: ghcr.io/example/api:1.0.0
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: http
            containerPort: 8080
            protocol: TCP
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
      terminationGracePeriodSeconds: 30
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web-public-ingress
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: ingress-no-tls
    app.kubernetes.io/component: web
    helm.sh/environment: staging
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
  
spec:
  ingressClassName: nginx
  
  rules:
    - host: api.example.org
      http:
        paths:
        -
          path: /
          pathType: Prefix
          backend:
            service:
              name: web
              port:
                name: http
