---
# Source: common-smoke/templates/all.yaml
apiVersion: batch/v1
kind: Job
metadata:
  name: run-task
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: internal-platform
    app.kubernetes.io/component: run-task
    helm.sh/environment: staging
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
spec:
  backoffLimit: 0
  template:
    metadata:
      labels:
        helm.sh/chart: common-smoke-0.1.0
        app.kubernetes.io/name: internal-platform
        app.kubernetes.io/component: run-task
        helm.sh/environment: staging
        app.kubernetes.io/instance: smoke
        app.kubernetes.io/managed-by: Helm
      annotations:
        checksum/config: abc123
        example.com/job-owner: platform-team
    spec:
      containers:
        - name: run-task
          image: ghcr.io/example/jobs:latest
          imagePullPolicy: "IfNotPresent"
          command: 
            - /bin/sh
            - -c
          args: 
            - echo job
      restartPolicy: "Never"
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: batch/v1
kind: CronJob
metadata:
  name: sync-task
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: internal-platform
    app.kubernetes.io/component: sync-task
    helm.sh/environment: staging
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
spec:
  schedule: "*/5 * * * *"
  concurrencyPolicy: "Forbid"
  successfulJobsHistoryLimit: 1
  failedJobsHistoryLimit: 1
  jobTemplate:
    spec:
      backoffLimit: 0
      template:
        metadata:
          labels:
            helm.sh/chart: common-smoke-0.1.0
            app.kubernetes.io/name: internal-platform
            app.kubernetes.io/component: sync-task
            helm.sh/environment: staging
            app.kubernetes.io/instance: smoke
            app.kubernetes.io/managed-by: Helm
          annotations:
            checksum/config: def456
            example.com/cron-owner: platform-team
        spec:
          priorityClassName: "high-priority"
          containers:
            - name: sync-task
              image: ghcr.io/example/cron:latest
              imagePullPolicy: "IfNotPresent"
              command: 
                - /bin/sh
                - -c
              args: 
                - echo cron
          restartPolicy: "Never"
          securityContext:
            seccompProfile:
              type: RuntimeDefault
          automountServiceAccountToken: false
