# Source: common-smoke/templates/all.yaml
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: web
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
spec:
  maxUnavailable: 25%
  selector:
    matchLabels:
      app.kubernetes.io/name: legacy-service
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ServiceAccount
metadata:
  name: web
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: web
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
  annotations:
    werf.io/weight: "-1"
data:
---
# Source: common-smoke/templates/all.yaml
kind: PersistentVolumeClaim
apiVersion: v1
metadata:
  name: data
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: stateful
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
spec:
  accessModes: [ReadWriteOnce]
  resources:
    requests:
      storage: "1Gi"
