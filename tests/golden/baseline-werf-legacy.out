# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Service
metadata:
  name: web
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 3000
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Service
metadata:
  name: stateful-headless
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: stateful
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
    service.kubernetes.io/headless: "true"
spec:
  type: ClusterIP
  clusterIP: None
  ports:
    - name: http
      port: 3001
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: stateful
    app.kubernetes.io/instance: smoke
  publishNotReadyAddresses: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
  annotations:
    werf.io/no-activity-timeout: "6m"
    werf.io/failures-allowed-per-replica: "3"
spec:
  replicas: 1
  minReadySeconds: 10
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 25%
      maxSurge: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: legacy-service
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        app.kubernetes.io/name: legacy-service
        app.kubernetes.io/component: web
        helm.sh/environment: production
        app.kubernetes.io/instance: smoke
    spec:
      containers:
        - name: web
          image: ghcr.io/example/legacy-app:9.9.9
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: http
            containerPort: 3000
            protocol: TCP
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
      terminationGracePeriodSeconds: 30
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: stateful
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: stateful
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
  annotations:
    werf.io/no-activity-timeout: "6m"
    werf.io/failures-allowed-per-replica: "3"
spec:
  serviceName: "stateful-headless"
  updateStrategy:
    type: "RollingUpdate"
  podManagementPolicy: "OrderedReady"
  minReadySeconds: 0
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: legacy-service
      app.kubernetes.io/component: stateful
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        app.kubernetes.io/name: legacy-service
        app.kubernetes.io/component: stateful
        helm.sh/environment: production
        app.kubernetes.io/instance: smoke
    spec:
      containers:
        - name: stateful
          image: ghcr.io/example/legacy-app:9.9.9
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: http
            containerPort: 3001
            protocol: TCP
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          volumeMounts:
            - name: data
              mountPath: /mnt/data
      terminationGracePeriodSeconds: 30
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: data
      automountServiceAccountToken: false
  volumeClaimTemplates:
    - metadata:
        name: data
        labels:
          app.kubernetes.io/name: legacy-service
          app.kubernetes.io/component: stateful
          helm.sh/environment: production
          app.kubernetes.io/instance: smoke
      spec: 
        accessModes: [ReadWriteOnce]
        resources:
          requests:
            storage: "1Gi"
---
# Source: common-smoke/templates/all.yaml
apiVersion: batch/v1
kind: Job
metadata:
  name: run-task
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: run-task
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
  annotations:
    werf.io/no-activity-timeout: "6m"
    werf.io/failures-allowed-per-replica: "3"
spec:
  backoffLimit: 0
  template:
    metadata:
      labels:
        app.kubernetes.io/name: legacy-service
        app.kubernetes.io/component: run-task
        helm.sh/environment: production
        app.kubernetes.io/instance: smoke
    spec:
      containers:
        - name: run-task
          image: ghcr.io/example/legacy-app:9.9.9
          imagePullPolicy: "IfNotPresent"
          command: 
            - /bin/sh
            - -c
          args: 
            - echo legacy job
      restartPolicy: "Never"
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: batch/v1
kind: CronJob
metadata:
  name: sync-task
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: sync-task
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
  annotations:
    werf.io/no-activity-timeout: "6m"
    werf.io/failures-allowed-per-replica: "3"
spec:
  schedule: "0 * * * *"
  concurrencyPolicy: "Forbid"
  successfulJobsHistoryLimit: 1
  failedJobsHistoryLimit: 1
  jobTemplate:
    spec:
      backoffLimit: 0
      template:
        metadata:
          labels:
            app.kubernetes.io/name: legacy-service
            app.kubernetes.io/component: sync-task
            helm.sh/environment: production
            app.kubernetes.io/instance: smoke
        spec:
          containers:
            - name: sync-task
              image: ghcr.io/example/legacy-app:9.9.9
              imagePullPolicy: "IfNotPresent"
              command: 
                - /bin/sh
                - -c
              args: 
                - echo legacy cron
          restartPolicy: "Never"
          securityContext:
            seccompProfile:
              type: RuntimeDefault
          automountServiceAccountToken: false

---
# Source: common-smoke/templates/all.yaml
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: web-external-ingress
  labels:
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
  
spec:
  
  rules:
    - host: legacy.example.com
      http:
        paths:
        -
          path: /
          pathType: ImplementationSpecific
          backend:
            service:
              name: web
              port:
                name: http
---
# Source: common-smoke/templates/all.yaml
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: legacy-secrets
  labels: 
    app.kubernetes.io/name: legacy-service
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
  annotations: 
    force-sync: "<NOW>"
    werf.io/weight: "-1"
spec:
  refreshInterval: "10000h"
  secretStoreRef:
    name: example-store
    kind: ClusterSecretStore
  target:
    name: legacy-secrets
    creationPolicy: Owner
  data:
      - secretKey: TOKEN
        remoteRef:
          key: /legacy/app
          property: TOKEN
