---
# Source: common-smoke/templates/all.yaml
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: web
  labels:
    app.kubernetes.io/name: vpa-app
    app.kubernetes.io/component: web
    app.kubernetes.io/environment: dev
    app.kubernetes.io/instance: smoke
spec:
  maxUnavailable: 25%
  selector:
    matchLabels:
      app.kubernetes.io/name: vpa-app
      app.kubernetes.io/component: web
      app.kubernetes.io/environment: dev
      app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ServiceAccount
metadata:
  name: web
  labels:
    app.kubernetes.io/name: vpa-app
    app.kubernetes.io/component: web
    app.kubernetes.io/environment: dev
    app.kubernetes.io/instance: smoke
automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: web
  labels:
    app.kubernetes.io/name: vpa-app
    app.kubernetes.io/component: web
    app.kubernetes.io/environment: dev
    app.kubernetes.io/instance: smoke
data:
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Service
metadata:
  name: web
  labels:
    app.kubernetes.io/name: vpa-app
    app.kubernetes.io/component: web
    app.kubernetes.io/environment: dev
    app.kubernetes.io/instance: smoke
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8080
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: vpa-app
    app.kubernetes.io/component: web
    app.kubernetes.io/environment: dev
    app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
  labels:
    app.kubernetes.io/name: vpa-app
    app.kubernetes.io/component: web
    app.kubernetes.io/environment: dev
    app.kubernetes.io/instance: smoke
spec:
  replicas: 1
  minReadySeconds: 10
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 25%
      maxSurge: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: vpa-app
      app.kubernetes.io/component: web
      app.kubernetes.io/environment: dev
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        app.kubernetes.io/name: vpa-app
        app.kubernetes.io/component: web
        app.kubernetes.io/environment: dev
        app.kubernetes.io/instance: smoke
    spec:
      containers:
        - name: web
          image: ghcr.io/example/web:1.0.0
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: http
            containerPort: 8080
            protocol: TCP
          readinessProbe:
            httpGet:
              path: /health_check/full
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 5
            timeoutSeconds: 3
          livenessProbe:
            httpGet:
              path: /health_check/full
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 5
            timeoutSeconds: 3
          securityContext:
            allowPrivilegeEscalation: false
            runAsNonRoot: true
      terminationGracePeriodSeconds: 30
      securityContext:
        runAsUser: 1000
        runAsGroup: 3000
        seccompProfile:
          type: RuntimeDefault
      serviceAccountName: web
---
# Source: common-smoke/templates/all.yaml
apiVersion: autoscaling.k8s.io/v1
kind: VerticalPodAutoscaler
metadata:
  name: web
  labels:
    app.kubernetes.io/name: vpa-app
    app.kubernetes.io/component: web
    app.kubernetes.io/environment: dev
    app.kubernetes.io/instance: smoke
spec:
  targetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: web
  updatePolicy: 
    updateMode: Auto
  resourcePolicy: 
    containerPolicies:
    - containerName: '*'
      controlledResources:
      - cpu
      - memory
      maxAllowed:
        cpu: 2
        memory: 2Gi
      minAllowed:
        cpu: 100m
        memory: 128Mi
