---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: logShipper
  labels:
    app.kubernetes.io/name: ds-app
    app.kubernetes.io/component: logShipper
    app.kubernetes.io/environment: dev
    app.kubernetes.io/instance: smoke
spec:
  minReadySeconds: 0
  revisionHistoryLimit: 3
  updateStrategy: 
    rollingUpdate:
      maxUnavailable: 1
    type: RollingUpdate
  selector:
    matchLabels:
      app.kubernetes.io/name: ds-app
      app.kubernetes.io/component: logShipper
      app.kubernetes.io/environment: dev
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        app.kubernetes.io/name: ds-app
        app.kubernetes.io/component: logShipper
        app.kubernetes.io/environment: dev
        app.kubernetes.io/instance: smoke
    spec:
      containers:
        - name: logShipper
          image: ghcr.io/example/log-shipper:1.0.0
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: metrics
            containerPort: 9090
            protocol: TCP
          readinessProbe:
            httpGet:
              path: /health_check/full
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 5
            timeoutSeconds: 3
          livenessProbe:
            httpGet:
              path: /health_check/full
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 5
            timeoutSeconds: 3
          securityContext:
            allowPrivilegeEscalation: false
            runAsNonRoot: true
      terminationGracePeriodSeconds: 30
      securityContext:
        runAsUser: 1000
        runAsGroup: 3000
        seccompProfile:
          type: RuntimeDefault
      tolerations:
        -
          operator: "Exists"
          effect: "NoSchedule"
      serviceAccountName: "default"
      hostNetwork: true
      hostPID: true
