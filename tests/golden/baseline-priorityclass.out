---
# Source: common-smoke/templates/all.yaml
apiVersion: scheduling.k8s.io/v1
kind: PriorityClass
metadata:
  name: app-critical
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: pc-app
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
value: 1e+06
globalDefault: false
description: "Critical workloads"
preemptionPolicy: PreemptLowerPriority
