---
# Source: common-smoke/templates/all.yaml
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: schema-global
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  maxUnavailable: 25%
  selector:
    matchLabels:
      app.kubernetes.io/name: schema-global
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ServiceAccount
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: schema-global
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: schema-global
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
data:
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Service
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: schema-global
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8080
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: schema-global
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: schema-global
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  minReadySeconds: 10
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 25%
      maxSurge: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: schema-global
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        helm.sh/chart: common-smoke-0.1.0
        app.kubernetes.io/name: schema-global
        app.kubernetes.io/component: web
        app.kubernetes.io/instance: smoke
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/version: "7.8.9"
    spec:
      containers:
        - name: web
          image: ghcr.io/example/web:1.0.0
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: http
            containerPort: 8080
            protocol: TCP
          envFrom:
            - configMapRef:
                name: "shared-config"
            - secretRef:
                name: "shared-secret"
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 7
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 7
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          securityContext:
            allowPrivilegeEscalation: false
            runAsNonRoot: true
            readOnlyRootFilesystem: true
            capabilities:
              drop:
              - ALL
      terminationGracePeriodSeconds: 30
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: app-secrets
  labels: 
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: schema-global
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
  annotations: 
    force-sync: "<NOW>"
spec:
  refreshInterval: "10000h"
  secretStoreRef:
    name: cluster-store
    kind: ClusterSecretStore
  target:
    name: app-secrets
    creationPolicy: Owner
  data:
      - secretKey: TOKEN
        remoteRef:
          key: app
          property: TOKEN
---
# Source: common-smoke/templates/all.yaml
apiVersion: keda.sh/v1alpha1
kind: ScaledObject
metadata:
  name: web
  labels:
    helm.sh/chart: common-smoke-0.1.0
    app.kubernetes.io/name: schema-global
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/version: "7.8.9"
spec:
  scaleTargetRef:
    name: web
    kind: Deployment
  pollingInterval: 30
  cooldownPeriod: 180
  minReplicaCount: 1
  maxReplicaCount: 3
  advanced:
    restoreToOriginalReplicaCount: false
  fallback:
    failureThreshold: 3
    replicas: 1
  triggers:
    - type: prometheus
      metadata:
        serverAddress: http://prometheus.monitoring:9090
        threshold: "1"
        query: "vector(1)"
