---
# Source: common-smoke/templates/all.yaml
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: web
  labels:
    app.kubernetes.io/name: tpl-scoping
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
spec:
  maxUnavailable: 25%
  selector:
    matchLabels:
      app.kubernetes.io/name: tpl-scoping
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ServiceAccount
metadata:
  name: web
  labels:
    app.kubernetes.io/name: tpl-scoping
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Secret
metadata:
  name: app-bootstrap
  labels:
    app.kubernetes.io/name: tpl-scoping
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
type: Opaque
stringData:
  RELEASE_REV: "1"
  TOKEN_SCOPE: "Opaque"

---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: web
  labels:
    app.kubernetes.io/name: tpl-scoping
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
data:
  OWN_TAG: "1.0.0"
  URL: "https://ghcr.io/example/web.example.org"
---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Service
metadata:
  name: web
  labels:
    app.kubernetes.io/name: tpl-scoping
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8080
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: tpl-scoping
    app.kubernetes.io/component: web
    app.kubernetes.io/instance: smoke
---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
  labels:
    app.kubernetes.io/name: tpl-scoping
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
spec:
  minReadySeconds: 10
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 25%
      maxSurge: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: tpl-scoping
      app.kubernetes.io/component: web
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        app.kubernetes.io/name: tpl-scoping
        app.kubernetes.io/component: web
        helm.sh/environment: production
        app.kubernetes.io/instance: smoke
    spec:
      containers:
        - name: web
          image: ghcr.io/example/web:1.0.0
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: http
            containerPort: 8080
            protocol: TCP
          env:
          - name: SAFE
            value: "1.0.0"
          - name: SCOPED_OK
            value: "ghcr.io/example/web"
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          securityContext:
            allowPrivilegeEscalation: false
            runAsNonRoot: true
            readOnlyRootFilesystem: true
            capabilities:
              drop:
              - ALL
      terminationGracePeriodSeconds: 30
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      automountServiceAccountToken: false
---
# Source: common-smoke/templates/all.yaml
apiVersion: keda.sh/v1alpha1
kind: ScaledObject
metadata:
  name: web
  labels:
    app.kubernetes.io/name: tpl-scoping
    app.kubernetes.io/component: web
    helm.sh/environment: production
    app.kubernetes.io/instance: smoke
spec:
  scaleTargetRef:
    name: web
    kind: Deployment
  pollingInterval: 30
  cooldownPeriod: 180
  minReplicaCount: 1
  maxReplicaCount: 3
  advanced:
    restoreToOriginalReplicaCount: false
  fallback:
    failureThreshold: 3
    replicas: 1
  triggers:
    - type: prometheus
      metadata:
        serverAddress: http://prometheus.monitoring.svc:9090
        threshold: "100"
        query: "rate(http_requests_total{app='ghcr.io/example/web'}[1m])"
