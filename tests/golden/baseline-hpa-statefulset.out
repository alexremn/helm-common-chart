---
# Source: common-smoke/templates/all.yaml
apiVersion: v1
kind: Service
metadata:
  name: stateful-headless
  labels:
    app.kubernetes.io/name: hpa-sts-app
    app.kubernetes.io/component: stateful
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
    service.kubernetes.io/headless: "true"
spec:
  type: ClusterIP
  clusterIP: None
  ports:
    - name: http
      port: 8080
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: hpa-sts-app
    app.kubernetes.io/component: stateful
    app.kubernetes.io/instance: smoke
  publishNotReadyAddresses: false


    # "Skipping PVC for component 'stateful': no persistence defined"
---
# Source: common-smoke/templates/all.yaml
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: stateful
  labels:
    app.kubernetes.io/name: hpa-sts-app
    app.kubernetes.io/component: stateful
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: StatefulSet
    name: stateful
  minReplicas: 2
  maxReplicas: 10
  metrics: 
    - resource:
        name: cpu
        target:
          averageUtilization: 70
          type: Utilization
      type: Resource

---
# Source: common-smoke/templates/all.yaml
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: stateful
  labels:
    app.kubernetes.io/name: hpa-sts-app
    app.kubernetes.io/component: stateful
    helm.sh/environment: dev
    app.kubernetes.io/instance: smoke
spec:
  serviceName: "stateful-headless"
  updateStrategy:
    type: "RollingUpdate"
  podManagementPolicy: "OrderedReady"
  minReadySeconds: 0
  selector:
    matchLabels:
      app.kubernetes.io/name: hpa-sts-app
      app.kubernetes.io/component: stateful
      app.kubernetes.io/instance: smoke
  template:
    metadata:
      labels:
        app.kubernetes.io/name: hpa-sts-app
        app.kubernetes.io/component: stateful
        helm.sh/environment: dev
        app.kubernetes.io/instance: smoke
    spec:
      containers:
        - name: stateful
          image: ghcr.io/example/web:1.0.0
          imagePullPolicy: "IfNotPresent"
          ports:
          - name: http
            containerPort: 8080
            protocol: TCP
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 0
            periodSeconds: 10
            failureThreshold: 3
            timeoutSeconds: 1
      terminationGracePeriodSeconds: 30
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      automountServiceAccountToken: false
