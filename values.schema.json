{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hubstaff.com/helm/common/values.schema.json",
  "title": "common (library chart) values",
  "description": "Library chart -- a consumer chart's values are validated against this schema. The library itself only ships an empty `global: {}`.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "description": "Application name (label app.kubernetes.io/name). See docs/values-contract.md for the full resolution order."
    },
    "environment": {
      "type": "string",
      "description": "Deployment environment label."
    },
    "env": {
      "type": "string",
      "description": "Deprecated alias of `environment`."
    },
    "app": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" }
      }
    },
    "global": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "environment": { "type": "string" },
        "env": { "type": "string" },
        "profile": {
          "type": "string",
          "enum": ["rails", "generic", "python", "go"],
          "description": "Selects a set of library defaults (probe paths, podMonitor metricRelabelings, envFrom phantom names). Default `rails` preserves v1.3.1 behavior."
        },
        "image": { "$ref": "#/$defs/imageOrString" },
        "imagePullPolicy": { "$ref": "#/$defs/imagePullPolicy" },
        "imagePullSecrets": { "$ref": "#/$defs/imagePullSecrets" },
        "securityContext": { "$ref": "#/$defs/securityContext" },
        "ingress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "className": { "type": "string" },
            "annotations": { "$ref": "#/$defs/annotations" }
          }
        },
        "pdb": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "maxUnavailable": { "$ref": "#/$defs/intOrPercent" }
          }
        },
        "deployment": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "replicasOnCreationAnnotation": {
              "type": "string",
              "description": "Annotation key written with the initial replica count when the component has scaling.min but no explicit replicas. Empty disables. Defaults to werf.io/replicas-on-creation when werf annotations are enabled."
            }
          }
        },
        "hooks": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "preInstallEnvironments": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Environments where ConfigMaps/ExternalSecrets are emitted as pre-install,pre-upgrade hooks. Default: [review, demo]."
            },
            "weight": { "type": ["string", "integer"] }
          }
        },
        "werf": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "annotations": {
              "type": "boolean",
              "description": "Explicit override for emitting werf.io/* annotations. When unset, defaults to true if both werf.name and werf.env are present."
            }
          }
        },
        "compat": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "legacySelectorLabels": {
              "type": "boolean",
              "description": "Include `version` and `extraLabels` in `common.labels.matchLabels`. Use only when migrating a chart whose pre-1.3 release stored those labels in selectors -- changing selector contents on existing Deployments/StatefulSets is not allowed by Kubernetes."
            }
          }
        }
      }
    },
    "werf": {
      "type": "object",
      "description": "Legacy werf-style values. Supported as fallback for name/env/image but no longer required.",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "env": { "type": "string" },
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "app": { "type": "string" },
            "pullPolicy": { "$ref": "#/$defs/imagePullPolicy" }
          }
        }
      }
    },
    "images": {
      "type": "object",
      "description": "Per-component image overrides keyed by component name (DNS or values-key form).",
      "additionalProperties": { "$ref": "#/$defs/imageOrString" }
    },
    "configs": {
      "type": "object",
      "description": "Top-level extra ConfigMaps. Each entry produces a ConfigMap.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "data": { "type": "object" }
        }
      }
    },
    "secrets": {
      "type": "object",
      "description": "ExternalSecret entries.",
      "additionalProperties": true
    },
    "jobs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/component" }
    },
    "cronjobs": {
      "type": "object",
      "additionalProperties": {
        "allOf": [
          { "$ref": "#/$defs/component" },
          {
            "type": "object",
            "required": ["schedule"],
            "properties": {
              "schedule": { "type": "string" }
            }
          }
        ]
      }
    },
    "nativeSecrets": {
      "type": "object",
      "description": "Native K8s Secret entries (chart.secret).",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "type": { "type": "string" },
          "immutable": { "type": "boolean" },
          "data": { "type": "object" },
          "stringData": { "type": "object" }
        }
      }
    },
    "prometheusRules": {
      "type": "object",
      "description": "PrometheusRule entries (chart.prometheusrule).",
      "additionalProperties": true
    },
    "priorityClasses": {
      "type": "object",
      "description": "PriorityClass entries (chart.priorityclass). Cluster-scoped.",
      "additionalProperties": true
    },
    "triggerAuthentications": {
      "type": "object",
      "description": "KEDA TriggerAuthentication entries (chart.triggerauth). Set .cluster: true for ClusterTriggerAuthentication.",
      "additionalProperties": true
    },
    "networkPolicies": {
      "type": "object",
      "description": "Top-level freeform NetworkPolicy entries (chart.networkpolicy). Per-component networkPolicy: lives under <component>.",
      "additionalProperties": true
    },
    "rbac": {
      "type": "object",
      "description": "Top-level freeform RBAC entries (chart.rbac). Per-component .rbac / .rbacCluster live under <component>.",
      "additionalProperties": true
    }
  },
  "patternProperties": {
    "^[A-Za-z][A-Za-z0-9_]*$": { "$ref": "#/$defs/componentLike" }
  },
  "$defs": {
    "imagePullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"]
    },
    "imageOrString": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "image": { "type": "string" },
            "registry": { "type": "string" },
            "repository": { "type": "string" },
            "name": { "type": "string" },
            "tag": { "type": ["string", "number"] },
            "digest": { "type": "string" },
            "pullPolicy": { "$ref": "#/$defs/imagePullPolicy" }
          }
        }
      ]
    },
    "annotations": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "intOrPercent": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string", "pattern": "^[0-9]+%$" }
      ]
    },
    "imagePullSecrets": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["name"],
                "properties": { "name": { "type": "string" } }
              }
            ]
          }
        },
        {
          "type": "object",
          "required": ["name"],
          "properties": { "name": { "type": "string" } }
        }
      ]
    },
    "componentLike": {
      "description": "Shape a consumer chart uses for component-keyed values (e.g. web, worker). Loose by design -- many chart helpers tolerate missing keys.",
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "string" },
        { "type": "number" },
        { "type": "array" },
        { "$ref": "#/$defs/component" }
      ]
    },
    "component": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "image": { "$ref": "#/$defs/imageOrString" },
        "imagePullPolicy": { "$ref": "#/$defs/imagePullPolicy" },
        "imagePullSecrets": { "$ref": "#/$defs/imagePullSecrets" },
        "securityContext": { "$ref": "#/$defs/securityContext" },
        "replicas": { "type": "integer", "minimum": 0 },
        "minReadySeconds": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
        "progressDeadlineSeconds": { "type": "integer", "minimum": 0 },
        "paused": { "type": "boolean" },
        "hpa": { "type": "object", "additionalProperties": true },
        "vpa": { "type": "object", "additionalProperties": true },
        "daemonSet": { "type": "object", "additionalProperties": true },
        "serviceMonitor": { "type": "object", "additionalProperties": true },
        "networkPolicy": { "type": "object", "additionalProperties": true },
        "rbac": { "type": "object", "additionalProperties": true },
        "rbacCluster": { "type": "object", "additionalProperties": true },
        "strategyType": { "type": "string", "enum": ["RollingUpdate", "Recreate"] },
        "strategyMaxUnavailable": { "$ref": "#/$defs/intOrPercent" },
        "strategyMaxSurge": { "$ref": "#/$defs/intOrPercent" },
        "command": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "args": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "ports": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "integer", "minimum": 1, "maximum": 65535 },
              {
                "type": "object",
                "required": ["containerPort"],
                "properties": {
                  "containerPort": { "type": "integer" },
                  "protocol": { "type": "string", "enum": ["TCP", "UDP", "SCTP"] },
                  "hostPort": { "type": "integer" }
                }
              }
            ]
          }
        },
        "ingress": {
          "oneOf": [
            { "type": "array", "items": { "$ref": "#/$defs/ingressEntry" } },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "annotations": { "$ref": "#/$defs/annotations" }
              }
            }
          ]
        },
        "service": { "type": "object" },
        "scaling": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "min": { "type": "integer", "minimum": 0 },
            "max": { "type": "integer", "minimum": 0 },
            "triggers": { "type": "array" }
          }
        },
        "pdb": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "minAvailable": { "$ref": "#/$defs/intOrPercent" },
            "maxUnavailable": { "$ref": "#/$defs/intOrPercent" }
          }
        },
        "podMonitor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "portName": { "type": "string" },
            "path": { "type": "string" }
          }
        },
        "serviceAccount": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string" },
            "automount": { "type": "boolean" }
          }
        },
        "persistence": {
          "oneOf": [
            { "type": "object" },
            { "type": "array", "items": { "type": "object" } }
          ]
        },
        "configmap": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "data": { "type": "object" },
            "binaryData": { "type": "object" }
          }
        },
        "annotations": { "$ref": "#/$defs/annotations" },
        "podAnnotations": { "$ref": "#/$defs/annotations" }
      }
    },
    "securityContext": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pod": { "type": "object", "additionalProperties": true },
        "container": { "type": "object", "additionalProperties": true }
      }
    },
    "ingressEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "$ref": "#/$defs/annotations" },
        "domains": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "host": { "type": "string" },
                  "paths": { "type": "array" }
                }
              }
            ]
          }
        },
        "tls": {
          "oneOf": [
            { "type": "boolean" },
            {
              "type": "object",
              "additionalProperties": true,
              "properties": { "secretName": { "type": "string" } }
            }
          ]
        }
      }
    }
  }
}
