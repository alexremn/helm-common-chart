# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Repo logo (served via raw URL, not needed inside the package)
icon.png
icon.svg
artifacthub-repo.yml
# Dev/CI tooling and internal docs — not part of the published library chart.
docs/
tests/
examples/
.github/
Makefile
.kube-linter.yaml
CLAUDE.md
AGENTS.md
RTK.md
CODEOWNERS
.claude/
.rtk/
